<mujoco model="simple_ball">
    <asset>
        <texture name="grid" type="2d" builtin="checker" rgb1=".1 .2 .3" rgb2=".2 .3 .4" width="300" height="300" mark="edge" markrgb=".8 .8 .8"/>
        <material name="grid" texture="grid" texrepeat="1 1" texuniform="true"/>
    </asset>

    <worldbody>
        <light pos="0 0 3" dir="0 0 -1"/>

        <geom name="floor" type="plane" size="5 5 0.1" material="grid"/>

        <body name="my_sphere" pos="0 0 10">
            <freejoint name="ball_joint"/>
            
            <geom type="sphere" size="0.1" rgba="0 1 0 1" mass="1"/>
        </body>
    </worldbody>
</mujoco>