<mujoco model="four_wheel_robot">
    <compiler angle="degree" coordinate="local" inertiafromgeom="true"/>
    
    <option gravity="0 0 -9.81" timestep="0.005"/>

    <asset>
        <texture name="grid" type="2d" builtin="checker" rgb1=".1 .2 .3" rgb2=".2 .3 .4" width="300" height="300"/>
        <material name="grid" texture="grid" texrepeat="1 1" texuniform="true"/>
        <material name="chassis_mat" rgba="0.2 0.6 0.8 1"/>
        <material name="wheel_mat" rgba="0.1 0.1 0.1 1"/>
    </asset>

    <worldbody>
        <light pos="0 0 5" dir="0 0 -1"/>
        <geom name="floor" type="plane" size="5 5 0.1" material="grid"/>

        <body name="chassis" pos="0 0 0.1">
            <freejoint name="root"/> 
            {{ 调整车体尺寸，使其更长以容纳四个轮子 }}
            <geom name="chassis_geom" type="box" size="0.4 0.25 0.1" material="chassis_mat"/>

            {{ 前左轮 }}
            <body name="front_left_wheel" pos="0.25 0.3 0" quat="0.707 0.707 0 0">
                <joint name="front_left_wheel_joint" type="hinge" axis="0 0 1" damping="0.1"/>
                <geom name="front_left_wheel_geom" type="cylinder" size="0.20 0.02" material="wheel_mat" friction="1 0.005 0.001"/>
            </body>

            {{ 前右轮 }}
            <body name="front_right_wheel" pos="0.25 -0.3 0" quat="0.707 0.707 0 0">
                <joint name="front_right_wheel_joint" type="hinge" axis="0 0 1" damping="0.1"/>
                <geom name="front_right_wheel_geom" type="cylinder" size="0.20 0.02" material="wheel_mat" friction="1 0.005 0.001"/>
            </body>

            {{ 后左轮 }}
            <body name="rear_left_wheel" pos="-0.25 0.3 0" quat="0.707 0.707 0 0">
                <joint name="rear_left_wheel_joint" type="hinge" axis="0 0 1" damping="0.1"/>
                <geom name="rear_left_wheel_geom" type="cylinder" size="0.20 0.02" material="wheel_mat" friction="1 0.005 0.001"/>
            </body>

            {{ 后右轮 }}
            <body name="rear_right_wheel" pos="-0.25 -0.3 0" quat="0.707 0.707 0 0">
                <joint name="rear_right_wheel_joint" type="hinge" axis="0 0 1" damping="0.1"/>
                <geom name="rear_right_wheel_geom" type="cylinder" size="0.20 0.02" material="wheel_mat" friction="1 0.005 0.001"/>
            </body>
        </body>
    </worldbody>

    <actuator>
        {{ 为四个轮子都添加执行器 }}
        <velocity name="front_left_motor" joint="front_left_wheel_joint" kv="10"/>
        <velocity name="front_right_motor" joint="front_right_wheel_joint" kv="10"/>
        <velocity name="rear_left_motor" joint="rear_left_wheel_joint" kv="10"/>
        <velocity name="rear_right_motor" joint="rear_right_wheel_joint" kv="10"/>
    </actuator>

    <sensor>
        {{ 为四个轮子都添加速度传感器 }}
        <jointvel name="front_left_vel" joint="front_left_wheel_joint"/>
        <jointvel name="front_right_vel" joint="front_right_wheel_joint"/>
        <jointvel name="rear_left_vel" joint="rear_left_wheel_joint"/>
        <jointvel name="rear_right_vel" joint="rear_right_wheel_joint"/>
        <framepos name="robot_pos" objtype="body" objname="chassis"/>
    </sensor>
</mujoco>