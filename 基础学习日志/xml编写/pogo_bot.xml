<mujoco model="pogo_bot">
    <compiler angle="degree" coordinate="local" inertiafromgeom="true"/>

    <option gravity="0 0 -9.81" timestep="0.002"/>

    <asset>
        <texture name="texplane" type="2d" builtin="checker" rgb1=".2 .3 .4" rgb2=".1 .1 .1" width="512" height="512"/>
        <material name="matplane" texture="texplane" texrepeat="1 1" texuniform="true"/>
        <material name="robot_metal" rgba="0.9 0.5 0.1 1" shininess="1"/>
    </asset>

    <worldbody>
        <light pos="0 0 3" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
        <geom name="floor" type="plane" size="0 0 .05" material="matplane"/>

        <body name="torso" pos="0 0 1.2">
            <freejoint name="root"/>
            <geom name="torso_geom" type="box" size="0.1 0.1 0.2" material="robot_metal"/>
            <geom name="head" type="sphere" size="0.08" pos="0 0 0.25" rgba="0.8 0.8 0.8 1"/>

            <!-- 添加的站点 -->
            <site name="torso_site" pos="0 0 0" size="0.01"/>
            <body name="leg" pos="0 0 -0.2">
                <joint name="leg_slide" type="slide" axis="0 0 1" range="-0.3 0" limited="true" stiffness="500" damping="10"/>
                <geom name="leg_geom" type="capsule" size="0.03" fromto="0 0 0 0 0 -0.4" rgba="0.2 0.2 0.2 1"/>
                
                <body name="foot" pos="0 0 -0.4">
                    <geom name="foot_geom" type="sphere" size="0.05" friction="1.5 0.1 0.1"/>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>
        <position name="jump_motor" joint="leg_slide" kp="2000" ctrlrange="-0.3 0" forcerange="-500 500"/>
    </actuator>

    <sensor>
        <accelerometer name="torso_accel" site="torso_site"/>
        <jointpos name="leg_pos" joint="leg_slide"/>
    </sensor>
</mujoco>